{
  "expo": {
    "name": "CNHora",
    "slug": "cnhora-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0F2B6B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "br.com.cnhora.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F2B6B"
      },
      "package": "br.com.cnhora.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "scheme": "cnhora"
  }
}
